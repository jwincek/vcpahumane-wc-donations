{
	"name": "starter-shelter/starter-shelter-donations",
	"description": "Animal shelter donations, memberships, and memorials management using WordPress 6.9+ Abilities API.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"homepage": "https://github.com/starter-shelter/starter-shelter-donations",
	"authors": [
		{
			"name": "Starter Shelter",
			"homepage": "https://github.com/starter-shelter"
		}
	],
	"require": {
		"php": ">=8.1"
	},
	"require-dev": {
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"wp-coding-standards/wpcs": "^3.0",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"yoast/phpunit-polyfills": "^2.0"
	},
	"autoload": {
		"psr-4": {
			"Starter_Shelter\\": "includes/"
		},
		"files": [
			"includes/core/helpers.php"
		]
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"sort-packages": true
	},
	"scripts": {
		"lint": "phpcs",
		"lint:fix": "phpcbf"
	}
}
