{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "starter-shelter/memorial-archive",
    "version": "2.1.0",
    "title": "Memorial Archive (Deprecated)",
    "category": "starter-shelter",
    "icon": "heart",
    "description": "Deprecated — use Memorial Wall instead. Existing instances render via the Memorial Wall block.",
    "keywords": [],
    "textdomain": "starter-shelter",
    "supports": {
        "inserter": false,
        "html": false
    },
    "attributes": {
        "archiveId": { "type": "string" },
        "perPage": { "type": "number", "default": 12 },
        "columns": { "type": "number", "default": 3 },
        "showSearch": { "type": "boolean", "default": true },
        "showFilters": { "type": "boolean", "default": true },
        "enhancedPagination": { "type": "boolean", "default": true },
        "defaultType": { "type": "string", "default": "all" }
    },
    "render": "file:./render.php"
}
